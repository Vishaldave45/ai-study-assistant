# ── Database ──
DATABASE_URL=postgresql://user:password@localhost:5432/ai_study_assistant

# ── Auth ──
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── LLM Providers ──
# Deployment-level defaults only. Per-workspace provider choice lives in the
# database (see docs/architecture.md — Config vs DB decision log).
DEFAULT_AI_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-1.5-pro

OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o

# ANTHROPIC_API_KEY=          # uncomment when Claude provider is added

# ── Embeddings ──
EMBEDDING_PROVIDER=gemini

# ── Vector Store ──
VECTOR_STORE_PROVIDER=faiss
FAISS_INDEX_PATH=./backend/app/rag/vectorstore/faiss_index

# ── Uploads ──
UPLOAD_STORAGE_PATH=./backend/storage/uploads
DEFAULT_UPLOAD_LIMIT_MB=50

# ── App ──
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
